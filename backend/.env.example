# App settings
# Optional for local non-Docker runs. Docker Compose already selects env files.
# ENV_FILE=.env.dev
APP_NAME="智慧發票管理與自動對帳系統 API"
APP_VERSION="0.1.0"
APP_DESCRIPTION="智慧發票管理與自動對帳系統的後端 API。"
APP_ENV="development"
DOCS_URL="/docs"
REDOC_URL="/redoc"
OPENAPI_URL="/openapi.json"
# Production can disable API docs by setting these to empty values:
# DOCS_URL=
# REDOC_URL=
# OPENAPI_URL=
LOG_LEVEL="INFO"
LOG_FILE_PATH="logs/app.log"
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# JWT
# If Supabase uses HS256, set the JWT secret from:
# Supabase Dashboard -> Project Settings -> API -> JWT Secret
SUPABASE_JWT_SECRET=

# Development auth fallback
# Keep this disabled in production.
ALLOW_DEV_FALLBACK=0
TEST_USER_ID=test-user-001

# OCR service
# When set, backend delegates OCR to the standalone service instead of loading PaddleOCR locally.
OCR_SERVICE_URL=
OCR_REQUEST_TIMEOUT=180

# Async OCR jobs
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
OCR_JOB_RESULT_EXPIRES=86400
